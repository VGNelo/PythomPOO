class Gafanhoto:
    def __init__(self):
        self.nome = ''
        self.idade = 0

    def aniversario(self):
        self.idade += 1

    def mensagem(self):
        return f"{self.nome} tem {self.idade} anos"


# Testando
g = Gafanhoto()
g.nome = "Valdemir"
g.idade = 30

print(g.mensagem())   # Valdemir tem 30 anos
g.aniversario()
print(g.mensagem())   # Valdemir tem 31 anos